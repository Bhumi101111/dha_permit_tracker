# ── SMTP (Nodemailer) ───────────────────────────────────────────────
# If these are left blank, OTP/receipt emails are logged to the server console
# instead of being sent (handy for local development).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=eVisa Tracker <no-reply@evisa.example>

# ── Stripe (test mode) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Auth ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ── URLs ────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
# Public URL of THIS server, used to build Stripe success_url.
SERVER_URL=http://localhost:4000
PORT=4000

# ── Pricing ─────────────────────────────────────────────────────────
SEARCH_RATE_EUR=2.50
